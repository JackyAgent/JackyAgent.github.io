---
import type { Lang } from '../i18n/ui';

interface Props {
  date: Date;
  lang?: Lang;
}

const { date, lang = 'zh' } = Astro.props;
const locale = lang === 'en' ? 'en-US' : 'zh-CN';
const formatted = new Intl.DateTimeFormat(locale, {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(date);
---

<time datetime={date.toISOString()} class="formatted-date">
  {formatted}
</time>

<style>
  .formatted-date {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }
</style>
