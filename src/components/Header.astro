---
import { useTranslations, localizePath, type Lang, defaultLang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const siteName = t('site.name');

const navItems = [
  { label: t('nav.home'), href: localizePath('/', lang), match: '/' },
  { label: t('nav.blog'), href: localizePath('/blog', lang), match: '/blog' },
  { label: t('nav.about'), href: localizePath('/about', lang), match: '/about' },
];

// 计算去掉 base 后、去掉语言前缀的相对路径，用于高亮与语言切换
const base = import.meta.env.BASE_URL; // '/' 或 '/my-website/'
const pathname = Astro.url.pathname;
const rel = pathname.startsWith(base) ? '/' + pathname.slice(base.length) : pathname;
const relNoLang = rel.replace(/^\/(en|zh)(?=\/|$)/, '') || '/';

const isActive = (match: string) => {
  if (match === '/') return relNoLang === '/';
  return relNoLang.startsWith(match);
};

// 语言切换：切到另一种语言的同一页面
const otherLang: Lang = lang === 'en' ? 'zh' : 'en';
const switchHref = localizePath(relNoLang, otherLang);
---

<header class="site-header">
  <div class="header-inner">
    <a href={localizePath('/', lang)} class="site-name">
      <span class="mono">{siteName}</span>
    </a>
    <div class="header-right">
      <nav class="nav">
        {navItems.map((item) => (
          <a
            href={item.href}
            class:list={['nav-link', { active: isActive(item.match) }]}
          >
            {item.label}
          </a>
        ))}
      </nav>
      <a href={switchHref} class="lang-switch" aria-label="Switch language">
        {t('lang.switch')}
      </a>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--header-height);
    background-color: var(--color-bg);
    border-bottom: 1px solid var(--color-border);
  }

  .header-inner {
    max-width: var(--max-width);
    height: 100%;
    margin: 0 auto;
    padding: 0 var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .site-name {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--color-text);
    text-decoration: none;
  }

  .site-name:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  .mono {
    font-family: var(--font-mono);
  }

  .header-right {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
    transition: color var(--transition), border-color var(--transition);
  }

  .nav-link:hover {
    color: var(--color-text);
    text-decoration: none;
  }

  .nav-link.active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
  }

  .lang-switch {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    text-decoration: none;
    padding: 0.2rem 0.55rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: color var(--transition), border-color var(--transition);
  }

  .lang-switch:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    text-decoration: none;
  }

  @media (max-width: 480px) {
    .header-right {
      gap: 1rem;
    }
    .nav {
      gap: 1rem;
    }
  }
</style>
