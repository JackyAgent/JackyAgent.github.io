---
import { type Lang } from '../i18n/ui';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;

// 文章阅读量显示改用「不蒜子 busuanzi」：纯前端、零配置、按 URL 自动统计 PV。
// 原因：Umami Cloud 免费版不含 Share 功能（无 Share 按钮、无只读 token 可走 share API），
// 故原本基于 /api/share/{token}/metrics 的方案不可行。
// 不蒜子与已上线的 Umami 埋点互不冲突：Umami 负责来源/页面/停留分析，不蒜子只显示阅读量数字。
// 不蒜子通过特定 id 的 span 自动填充当前页 PV（基于 URL 去重），脚本需 is:inline 原样保留。
const label = lang === 'zh' ? '阅读量' : 'Views';
---

<div class="view-counter">
  <span class="vc-text">{label}</span>
  <span id="busuanzi_value_page_pv" class="vc-count">0</span>
</div>

<script is:inline async src="//busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js"></script>

<style>
  .view-counter {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-top: 2.5rem;
    padding: 0.45rem 0.9rem;
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .vc-count {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-text);
  }
</style>
