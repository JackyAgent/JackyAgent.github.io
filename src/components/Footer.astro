---
import { useTranslations, type Lang, defaultLang } from '../i18n/ui';

interface Props {
  lang?: Lang;
}

const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const year = new Date().getFullYear();
const siteName = t('site.name');

const socialLinks = [
  { label: 'GitHub', href: 'https://github.com/JackyAgent' },
  { label: t('footer.email'), href: 'mailto:yang.jiaqi.hadoop@gmail.com' },
  { label: t('footer.zhihu'), href: 'https://www.zhihu.com/' },
  { label: t('footer.wechat'), href: 'javascript:void(0)' },
];
---

<footer class="site-footer">
  <div class="footer-inner">
    <p class="footer-text">
      © {year} {siteName} · {t('footer.builtWith')}
    </p>
    <div class="footer-links">
      {socialLinks.map((link) => (
        <a href={link.href} target="_blank" rel="noopener noreferrer">
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 1.5rem var(--content-padding);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .footer-text {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .footer-links {
    display: flex;
    gap: 1.2rem;
  }

  .footer-links a {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .footer-links a:hover {
    color: var(--color-accent);
  }

  @media (max-width: 480px) {
    .footer-inner {
      flex-direction: column;
      text-align: center;
    }
  }
</style>
