---
import FormattedDate from './FormattedDate.astro';
import { localizePath, type Lang, defaultLang } from '../i18n/ui';
import { getBlogSlug } from '../i18n/blog';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  lang?: Lang;
}

const { post, lang = defaultLang } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const href = localizePath(`/blog/${getBlogSlug(post.id)}/`, lang);
---

<article class="blog-card">
  <a href={href} class="card-link">
    <div class="card-date">
      <FormattedDate date={pubDate} lang={lang} />
    </div>
    <h3 class="card-title">{title}</h3>
    <p class="card-desc">{description}</p>
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map((tag) => (
          <span class="tag">#{tag}</span>
        ))}
      </div>
    )}
  </a>
</article>

<style>
  .blog-card {
    padding: 1.5rem 0;
    border-bottom: 1px solid var(--color-border);
    transition: opacity var(--transition);
  }

  .blog-card:hover {
    opacity: 0.85;
  }

  .card-link {
    display: block;
    color: inherit;
    text-decoration: none;
  }

  .card-link:hover {
    text-decoration: none;
  }

  .card-date {
    margin-bottom: 0.4rem;
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: var(--color-text);
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.6rem;
    line-height: 1.6;
  }

  .card-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-text-secondary);
    background-color: var(--color-bg-secondary);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius);
  }
</style>
