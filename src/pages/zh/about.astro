---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { useTranslations } from '../../i18n/ui';
import { resume } from '../../data/resume';

const lang = 'zh';
const t = useTranslations(lang);
const data = resume[lang];

const links = [
  { label: 'GitHub', href: 'https://github.com/JackyAgent', handle: '@JackyAgent' },
  { label: t('about.contact.email'), href: 'mailto:yang.jiaqi.hadoop@gmail.com', handle: 'yang.jiaqi.hadoop@gmail.com' },
  { label: t('about.contact.zhihu'), href: 'https://www.zhihu.com/', handle: '@JackyAgent' },
  { label: t('about.contact.wechat'), href: 'javascript:void(0)', handle: 'JackyYangPassion' },
];
---

<BaseLayout title={t('about.title')} description={t('about.description')} lang={lang}>
  <article class="about">
    <h1>{t('about.heading')}</h1>

    <section class="bio">
      {data.bio.map((p) => <p>{p}</p>)}
    </section>

    <section class="section">
      <h2>{t('about.experience.title')}</h2>
      <div class="timeline">
        {data.experience.map((item) => (
          <div class:list={['timeline-item', { current: item.current }]}>
            <div class="timeline-year">{item.period}</div>
            <div class="timeline-body">
              <div class="timeline-head">
                <h3 class="company">{item.company}</h3>
                <span class="role">{item.role}</span>
                <span class="location">{item.location}</span>
              </div>
              <ul class="highlights">
                {item.highlights.map((h) => <li>{h}</li>)}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>{t('about.skills.title')}</h2>
      <div class="skills-grid">
        {data.skills.map((group) => (
          <div class="skill-group">
            <h3 class="skill-category">{group.category}</h3>
            <div class="skill-tags">
              {group.items.map((item) => (
                <span class="skill-tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>{t('about.education.title')}</h2>
      <div class="edu-list">
        {data.education.map((edu) => (
          <div class="edu-item">
            <div class="edu-main">
              <span class="edu-school">{edu.school}</span>
              <span class="edu-degree">{edu.degree}</span>
            </div>
            <span class="edu-year">{edu.year}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>{t('about.awards.title')}</h2>
      <div class="award-list">
        {data.awards.map((award) => (
          <div class="award-item">
            <span class="award-year">{award.year}</span>
            <span class="award-title">{award.title}</span>
          </div>
        ))}
      </div>
    </section>

    <section class="section">
      <h2>{t('about.contact.title')}</h2>
      <div class="contact-list">
        {links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="contact-item">
            <span class="contact-label">{link.label}</span>
            <span class="contact-handle">{link.handle}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  h1 {
    font-size: 1.8rem;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: 1.3rem;
    margin-bottom: 1.2rem;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid var(--color-border);
  }

  .section {
    margin-bottom: 3rem;
  }

  .bio {
    margin-bottom: 3rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .bio p {
    margin-bottom: 1.2em;
  }

  /* ========== 时间轴 ========== */
  .timeline {
    --tl-gutter: 116px;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 8px;
    bottom: 8px;
    left: var(--tl-gutter);
    width: 2px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    display: grid;
    grid-template-columns: var(--tl-gutter) 1fr;
    column-gap: 1.75rem;
    padding-bottom: 2.5rem;
  }

  .timeline-item:last-child {
    padding-bottom: 0;
  }

  .timeline-year {
    text-align: right;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
    padding-top: 0.35rem;
    white-space: pre-line;
  }

  .timeline-item.current .timeline-year {
    color: var(--color-accent);
    font-weight: 600;
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(var(--tl-gutter) + 1px);
    top: 0.6rem;
    width: 12px;
    height: 12px;
    margin-left: -6px;
    border-radius: 50%;
    background: var(--color-bg);
    border: 2px solid var(--color-border);
    z-index: 1;
  }

  .timeline-item.current::before {
    background: var(--color-accent);
    border-color: var(--color-accent);
    box-shadow: 0 0 0 4px color-mix(in srgb, var(--color-accent) 20%, transparent);
  }

  .timeline-body {
    min-width: 0;
  }

  .timeline-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4rem 0.75rem;
    margin-bottom: 0.6rem;
  }

  .company {
    font-size: 1.1rem;
    margin: 0;
  }

  .role {
    font-size: 0.85rem;
    color: var(--color-accent);
    font-weight: 500;
  }

  .location {
    font-size: 0.78rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
  }

  .highlights {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .highlights li {
    position: relative;
    padding-left: 1.1rem;
    margin-bottom: 0.55rem;
    font-size: 0.9rem;
    line-height: 1.65;
    color: var(--color-text-secondary);
  }

  .highlights li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-accent);
  }

  /* ========== 技能 ========== */
  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .skill-group {
    padding: 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .skill-category {
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 0.8rem;
    letter-spacing: 0.05em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.85rem;
    padding: 0.25rem 0.7rem;
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  /* ========== 教育 ========== */
  .edu-list,
  .award-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .edu-item,
  .award-item {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .edu-main {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .edu-school {
    font-weight: 600;
  }

  .edu-degree {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  .edu-year,
  .award-year {
    font-family: var(--font-mono);
    font-size: 0.82rem;
    color: var(--color-accent);
    white-space: nowrap;
  }

  .award-title {
    font-size: 0.92rem;
  }

  /* ========== 联系 ========== */
  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background-color var(--transition);
  }

  .contact-item:hover {
    border-color: var(--color-accent);
    background-color: var(--color-bg-secondary);
    text-decoration: none;
  }

  .contact-label {
    font-weight: 500;
  }

  .contact-handle {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
    .timeline {
      --tl-gutter: 74px;
    }
    .timeline-year {
      font-size: 0.72rem;
    }
    .edu-item,
    .award-item {
      flex-direction: column;
      gap: 0.3rem;
    }
  }

  @media (prefers-reduced-motion: no-preference) {
    .timeline-item {
      animation: fadeUp 0.5s ease both;
    }
    .timeline-item:nth-child(1) { animation-delay: 0.05s; }
    .timeline-item:nth-child(2) { animation-delay: 0.12s; }
    .timeline-item:nth-child(3) { animation-delay: 0.19s; }
    .timeline-item:nth-child(4) { animation-delay: 0.26s; }
    .timeline-item:nth-child(5) { animation-delay: 0.33s; }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: none; }
    }
  }
</style>
