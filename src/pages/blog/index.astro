---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { useTranslations } from '../../i18n/ui';
import { getPostsByLang } from '../../i18n/blog';

const lang = 'en';
const t = useTranslations(lang);
const posts = await getPostsByLang(lang);
---

<BaseLayout title={t('blog.title')} description={t('blog.description')} lang={lang}>
  <h1>{t('blog.title')}</h1>
  <p class="page-desc">{t('blog.count')(posts.length)}</p>
  <div class="post-list">
    {posts.map((post) => (
      <BlogCard post={post} lang={lang} />
    ))}
  </div>
</BaseLayout>

<style>
  h1 {
    font-size: 1.8rem;
    margin-bottom: 0.3rem;
  }

  .page-desc {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 2rem;
    font-family: var(--font-mono);
  }
</style>
