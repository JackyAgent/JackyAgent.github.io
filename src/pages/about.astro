---
import BaseLayout from '../layouts/BaseLayout.astro';
import { useTranslations } from '../i18n/ui';

const lang = 'en';
const t = useTranslations(lang);

const skills = [
  { category: t('about.skills.backend'), items: ['Go', 'Rust', 'TypeScript', 'PostgreSQL', 'Redis'] },
  { category: t('about.skills.frontend'), items: ['React', 'Astro', 'Next.js', 'CSS'] },
  { category: t('about.skills.devops'), items: ['Docker', 'Kubernetes', 'Terraform', 'GitHub Actions'] },
  { category: t('about.skills.other'), items: t('about.skills.otherItems') },
];

const links = [
  { label: 'GitHub', href: 'https://github.com/JackyAgent', handle: '@JackyAgent' },
  { label: t('about.contact.email'), href: 'mailto:yang.jiaqi.hadoop@gmail.com', handle: 'yang.jiaqi.hadoop@gmail.com' },
  { label: t('about.contact.zhihu'), href: 'https://www.zhihu.com/', handle: '@JackyAgent' },
  { label: t('about.contact.wechat'), href: 'javascript:void(0)', handle: 'JackyYangPassion' },
];
---

<BaseLayout title={t('about.title')} description={t('about.description')} lang={lang}>
  <article class="about">
    <h1>{t('about.heading')}</h1>

    <section class="bio">
      <p>{t('about.bio.1')}</p>
      <p>{t('about.bio.2')}</p>
    </section>

    <section class="skills-section">
      <h2>{t('about.skills.title')}</h2>
      <div class="skills-grid">
        {skills.map((group) => (
          <div class="skill-group">
            <h3 class="skill-category">{group.category}</h3>
            <div class="skill-tags">
              {group.items.map((item) => (
                <span class="skill-tag">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <section class="contact-section">
      <h2>{t('about.contact.title')}</h2>
      <div class="contact-list">
        {links.map((link) => (
          <a href={link.href} target="_blank" rel="noopener noreferrer" class="contact-item">
            <span class="contact-label">{link.label}</span>
            <span class="contact-handle">{link.handle}</span>
          </a>
        ))}
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  h1 {
    font-size: 1.8rem;
    margin-bottom: 2rem;
  }

  h2 {
    font-size: 1.3rem;
    margin-bottom: 1.2rem;
  }

  .bio {
    margin-bottom: 3rem;
    line-height: 1.9;
    color: var(--color-text);
  }

  .bio p {
    margin-bottom: 1.2em;
  }

  .skills-section {
    margin-bottom: 3rem;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  .skill-group {
    padding: 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .skill-category {
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    font-family: var(--font-mono);
    margin-bottom: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    font-size: 0.85rem;
    padding: 0.25rem 0.7rem;
    background-color: var(--color-bg-secondary);
    border-radius: var(--radius);
    border: 1px solid var(--color-border);
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.2rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    text-decoration: none;
    color: inherit;
    transition: border-color var(--transition), background-color var(--transition);
  }

  .contact-item:hover {
    border-color: var(--color-accent);
    background-color: var(--color-bg-secondary);
    text-decoration: none;
  }

  .contact-label {
    font-weight: 500;
  }

  .contact-handle {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
  }

  @media (max-width: 600px) {
    .skills-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
